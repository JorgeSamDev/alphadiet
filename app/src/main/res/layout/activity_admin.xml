<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0F1E"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Agregar Producto"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre del producto"
            android:textSize="14sp"
            android:textColor="#8A93B8"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/et_nombre"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Ej: Creatina Birtman 500g"
            android:background="@drawable/bg_search_bar"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:textColorHint="#8A93B8"
            android:singleLine="true"
            android:layout_marginBottom="14dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Precio"
            android:textSize="14sp"
            android:textColor="#8A93B8"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/et_precio"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Ej: 550.24"
            android:background="@drawable/bg_search_bar"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:textColorHint="#8A93B8"
            android:inputType="numberDecimal"
            android:singleLine="true"
            android:layout_marginBottom="14dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Descuento"
            android:textSize="14sp"
            android:textColor="#8A93B8"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/et_descuento"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Ej: 20%"
            android:background="@drawable/bg_search_bar"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:textColorHint="#8A93B8"
            android:inputType="numberDecimal"
            android:singleLine="true"
            android:layout_marginBottom="14dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Categoría"
            android:textSize="14sp"
            android:textColor="#8A93B8"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/spinner_categoria"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_card_detail"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="14dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Descripción"
            android:textSize="14sp"
            android:textColor="#8A93B8"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/et_descripcion"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:hint="Descripción del producto"
            android:background="@drawable/bg_search_bar"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:textColorHint="#8A93B8"
            android:gravity="top"
            android:layout_marginBottom="14dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="URL de imagen"
            android:textSize="14sp"
            android:textColor="#8A93B8"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/et_imagen"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="https://..."
            android:background="@drawable/bg_search_bar"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:textColorHint="#8A93B8"
            android:inputType="textUri"
            android:singleLine="true"
            android:layout_marginBottom="20dp" />

        <!-- Macros dentro de una card, se agrupan visualmente -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_detail"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Valores nutricionales por scoop"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Calorías (kcal)"
                        android:textSize="12sp"
                        android:textColor="#8A93B8"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/et_calorias"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Ej: 120"
                        android:background="@drawable/bg_search_bar"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#8A93B8"
                        android:inputType="number"
                        android:singleLine="true" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Proteína (g)"
                        android:textSize="12sp"
                        android:textColor="#8A93B8"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/et_proteina"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Ej: 24"
                        android:background="@drawable/bg_search_bar"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#8A93B8"
                        android:inputType="number"
                        android:singleLine="true" />

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Carbohidratos (g)"
                        android:textSize="12sp"
                        android:textColor="#8A93B8"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/et_carbohidratos"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Ej: 3"
                        android:background="@drawable/bg_search_bar"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#8A93B8"
                        android:inputType="number"
                        android:singleLine="true" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Grasas (g)"
                        android:textSize="12sp"
                        android:textColor="#8A93B8"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/et_grasas"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Ej: 1"
                        android:background="@drawable/bg_search_bar"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#8A93B8"
                        android:inputType="number"
                        android:singleLine="true" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <Button
            android:id="@+id/btn_guardar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Guardar Producto"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_navy"
            android:backgroundTint="@null" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>