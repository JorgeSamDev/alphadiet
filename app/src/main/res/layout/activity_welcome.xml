<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_welcome"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/overlay" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="56dp"
            android:paddingBottom="32dp">

            <!-- Logo -->
            <TextView
                android:id="@+id/tv_logo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sam"
                android:textColor="@color/white"
                android:textSize="36sp"
                android:textStyle="bold" />

            <!-- Espaciado flexible -->
            <Space
                android:layout_width="match_parent"
                android:layout_height="292dp"
                android:layout_weight="1" />

            <!-- Título de bienvenida -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¡ Bienvenido !\nTu mejor versión\nte espera con\nAlpha Diet"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginBottom="36dp" />

            <!-- Botón ya tengo cuenta -->
            <Button
                android:id="@+id/btn_ya_tengo_cuenta"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Ya tengo cuenta"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/bg_button_navy"
                android:backgroundTint="@null"
                android:layout_marginBottom="12dp" />

            <!-- Botón registrarme -->
            <Button
                android:id="@+id/btn_registrarme"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Registrarme"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/bg_button_navy_dark"
                android:backgroundTint="@null"
                android:layout_marginBottom="22dp" />

            <!-- Divisor -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#44FFFFFF"
                android:layout_marginBottom="22dp" />

            <!-- Texto "Iniciar sesión con" -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="Iniciar sesión con"
                android:textColor="#A8FFFFFF"
                android:textSize="13sp"
                android:layout_marginBottom="18dp" />

            <!-- Iconos de redes sociales -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:orientation="horizontal"
                android:layout_marginBottom="28dp">

                <!-- Botón Google -->
                <ImageButton
                    android:id="@+id/btn_google"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_google_white"
                    android:background="@drawable/bg_social_circle"
                    android:contentDescription="Google"
                    android:layout_marginEnd="24dp"
                    android:padding="14dp" />

                <!-- Botón Instagram -->
                <ImageButton
                    android:id="@+id/btn_instagram"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_instagram_white"
                    android:background="@drawable/bg_social_circle"
                    android:contentDescription="Instagram"
                    android:layout_marginEnd="24dp"
                    android:padding="14dp" />

                <!-- Botón Facebook -->
                <ImageButton
                    android:id="@+id/btn_facebook"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_facebook_white"
                    android:background="@drawable/bg_social_circle"
                    android:contentDescription="Facebook"
                    android:padding="14dp" />

            </LinearLayout>

            <!-- Términos y privacidad -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:orientation="horizontal"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Al registrarte aceptas nuestros "
                    android:textColor="#88FFFFFF"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tv_terminos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Términos de Uso"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" y "
                    android:textColor="#88FFFFFF"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tv_privacidad"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Política de Privacidad"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</FrameLayout>