<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF0F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header azul con título -->


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Más populares -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Más populares"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingTop="8dp"
                android:paddingBottom="12dp"
                android:background="@color/navy_dark"
                android:textColor="#FFFFFF" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Popular 1 -->
                    <LinearLayout
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#C5CAFF"
                        android:padding="8dp"
                        android:layout_marginEnd="10dp">

                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:src="@android:drawable/ic_menu_gallery"
                            android:background="#FFFFFF"
                            android:padding="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Creatina Birtman"
                            android:textSize="10sp"
                            android:textColor="@color/navy_dark"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>

                    <!-- Popular 2 -->
                    <LinearLayout
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#C5CAFF"
                        android:padding="8dp"
                        android:layout_marginEnd="10dp">

                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:src="@android:drawable/ic_menu_gallery"
                            android:background="#FFFFFF"
                            android:padding="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Venom Inferno"
                            android:textSize="10sp"
                            android:textColor="@color/navy_dark"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>

                    <!-- Popular 3 -->
                    <LinearLayout
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#C5CAFF"
                        android:padding="8dp"
                        android:layout_marginEnd="10dp">

                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:src="@android:drawable/ic_menu_gallery"
                            android:background="#FFFFFF"
                            android:padding="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
