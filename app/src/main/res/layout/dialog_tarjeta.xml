<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <LinearLayout
        android:id="@+id/layout_formulario_tarjeta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Número de tarjeta"
            android:textSize="13sp"
            android:textColor="#8A93B8"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/et_numero_tarjeta"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="1234 5678 9012 3456"
            android:background="@drawable/bg_search_bar"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#5A6488"
            android:inputType="number"
            android:maxLength="16"
            android:layout_marginBottom="14dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vencimiento"
                    android:textSize="13sp"
                    android:textColor="#8A93B8"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/et_vencimiento"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="MM/AA"
                    android:background="@drawable/bg_search_bar"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#5A6488"
                    android:maxLength="5" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CVV"
                    android:textSize="13sp"
                    android:textColor="#8A93B8"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/et_cvv"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="123"
                    android:background="@drawable/bg_search_bar"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#5A6488"
                    android:inputType="numberPassword"
                    android:maxLength="3" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_verificando"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="30dp"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:indeterminateTint="#4C6FFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Verificando tarjeta..."
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

    </LinearLayout>

</LinearLayout>