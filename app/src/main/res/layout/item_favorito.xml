<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="14dp"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_card_detail">

    <ImageView
        android:id="@+id/iv_imagen"
        android:layout_width="68dp"
        android:layout_height="68dp"
        android:scaleType="centerCrop"
        android:background="#1E294D"
        android:src="@android:drawable/ic_menu_gallery" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="14dp">

        <TextView
            android:id="@+id/tv_nombre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nombre"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Categoría"
            android:textSize="12sp"
            android:textColor="#8A93B8"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/tv_precio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$0.00"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#4C6FFF"
            android:layout_marginTop="8dp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btn_compartir"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_share_nav"
            android:background="@android:color/transparent"
            android:contentDescription="Compartir"
            android:layout_marginEnd="12dp" />

        <ImageButton
            android:id="@+id/btn_favorito"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/btn_star_big_on"
            android:background="@android:color/transparent"
            android:contentDescription="Quitar de favoritos" />

    </LinearLayout>

</LinearLayout>